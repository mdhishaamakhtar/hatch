FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/partition-archival ./cmd/partition-archival

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/partition-archival /usr/local/bin/partition-archival
EXPOSE 9026
USER nonroot:nonroot
ENTRYPOINT ["/usr/local/bin/partition-archival"]
