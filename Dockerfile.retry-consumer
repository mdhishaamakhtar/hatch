FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/retry-consumer ./cmd/retry-consumer

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/retry-consumer /usr/local/bin/retry-consumer
EXPOSE 9024
USER nonroot:nonroot
ENTRYPOINT ["/usr/local/bin/retry-consumer"]
