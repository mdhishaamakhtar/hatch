FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/delivery-worker ./cmd/delivery-worker

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/delivery-worker /usr/local/bin/delivery-worker
EXPOSE 9023
USER nonroot:nonroot
ENTRYPOINT ["/usr/local/bin/delivery-worker"]
