{
  "uid": "hatch-global-overview",
  "title": "Hatch — Global Performance Overview",
  "tags": ["hatch"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "SLA & Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "E2E latency p50",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 } ] } } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le))" } ]
    },
    {
      "type": "stat",
      "title": "E2E latency p95",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 } ] } } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le))" } ]
    },
    {
      "type": "stat",
      "title": "E2E latency p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 30 } ] } } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.99, sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le))" } ]
    },
    {
      "type": "stat",
      "title": "Delivered /min",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [ { "refId": "A", "expr": "sum(rate(hatch_delivery_sends_total{status=\"success\"}[5m])) * 60" } ]
    },
    {
      "type": "stat",
      "title": "Failed /min",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.01 } ] } } },
      "targets": [ { "refId": "A", "expr": "sum(rate(hatch_delivery_failed_total[5m])) * 60" } ]
    },
    {
      "type": "stat",
      "title": "Retrying /min",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "fixed", "fixedColor": "yellow" } } },
      "targets": [ { "refId": "A", "expr": "sum(rate(hatch_delivery_retries_total[5m])) * 60" } ]
    },
    {
      "type": "row",
      "title": "End-to-End Latency Distribution",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "heatmap",
      "title": "E2E latency heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "calculate": false, "cellGap": 1, "yAxis": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le)", "format": "heatmap", "legendFormat": "{{le}}" } ]
    },
    {
      "type": "timeseries",
      "title": "E2E latency p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(hatch_delivery_e2e_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "row",
      "title": "Pipeline Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "Delivery batch size (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 15 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(hatch_delivery_batch_size_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(hatch_delivery_batch_size_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Batch processing duration p95",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(hatch_delivery_batch_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" } ]
    },
    {
      "type": "timeseries",
      "title": "Scheduler wheel occupancy per pod",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 15 },
      "targets": [ { "refId": "A", "expr": "hatch_scheduler_wheel_occupied_slots", "legendFormat": "pod {{pod_index}}" } ]
    },
    {
      "type": "row",
      "title": "Failure Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "piechart",
      "title": "Terminal failures by reason (range total)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(increase(hatch_delivery_failed_total[$__range])) by (reason)", "legendFormat": "{{reason}}", "instant": true } ]
    },
    {
      "type": "timeseries",
      "title": "Retry volume by tier",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(hatch_delivery_retries_total[5m])) by (tier)", "legendFormat": "{{tier}}" } ]
    },
    {
      "type": "state-timeline",
      "title": "Circuit breaker state per provider",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF_OPEN", "color": "yellow" }, "2": { "text": "OPEN", "color": "red" } } } ] } },
      "options": { "mergeValues": true },
      "targets": [ { "refId": "A", "expr": "hatch_delivery_circuit_breaker_state", "legendFormat": "{{provider}}" } ]
    }
  ]
}
