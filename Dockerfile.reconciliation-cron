FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/reconciliation-cron ./cmd/reconciliation-cron

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/reconciliation-cron /usr/local/bin/reconciliation-cron
EXPOSE 9025
USER nonroot:nonroot
ENTRYPOINT ["/usr/local/bin/reconciliation-cron"]
