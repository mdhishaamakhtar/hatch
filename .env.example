# Hatch environment variables.
#
# Two audiences read this file:
#   1) HOST tools running on your laptop (make migrate, psql, redis-cli) —
#      they reach the cluster through port-forwards on localhost.
#   2) IN-CLUSTER services (api, scheduler, delivery-worker, …) — they MUST
#      talk to each other and to data infra via Kubernetes ClusterDNS.
#      No service ever uses localhost or any external endpoint.
#
# scripts/inject-secrets.sh strips every HOST_ key when populating the
# `hatch-secrets` k8s Secret, so pods cannot accidentally pick up the host
# variants.
#
# Copy this file to .env and replace placeholders before running `make up`.

# ─── HOST tools (port-forwarded) ──────────────────────────────────────────
HOST_DATABASE_URL=postgres://hatch:hatchpass@localhost:5432/hatch?sslmode=disable
HOST_REDIS_ADDR=localhost:6379
HOST_KAFKA_BROKERS=localhost:9092

# ─── In-cluster service config (ClusterDNS only) ──────────────────────────
POSTGRES_HOST=postgres.hatch.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=hatch
POSTGRES_USER=hatch
POSTGRES_PASSWORD=hatchpass
DATABASE_URL=postgres://hatch:hatchpass@postgres.hatch.svc.cluster.local:5432/hatch?sslmode=disable

REDIS_ADDR=redis.hatch.svc.cluster.local:6379

KAFKA_BROKERS=kafka.hatch.svc.cluster.local:9092

OTLP_ENDPOINT=observability-tempo.observability.svc.cluster.local:4317
LOKI_ENDPOINT=http://observability-loki-gateway.observability.svc.cluster.local

# ─── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ─── Alertmanager email receiver (placeholders) ───────────────────────────
ALERTMANAGER_SMTP_HOST=smtp.example.com:587
ALERTMANAGER_SMTP_FROM=alerts@example.com
ALERTMANAGER_SMTP_USER=
ALERTMANAGER_SMTP_PASSWORD=

# ─── Hatch admin API key (Phase 1 admin endpoints) ────────────────────────
ADMIN_API_KEY=changeme-admin-key

# ─── Mock provider tuning (consumed in benchmarks) ────────────────────────
MOCK_PROVIDER_LATENCY_MS=150
MOCK_PROVIDER_LATENCY_JITTER_MS=50
MOCK_PROVIDER_ERROR_RATE=0.001
MOCK_PROVIDER_RATE_LIMIT_RATE=0.0
