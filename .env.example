# Hatch environment variables.
#
# Two audiences read this file:
#   1) HOST tools running on your laptop (make migrate, psql, redis-cli) —
#      they reach the cluster through port-forwards on localhost.
#   2) IN-CLUSTER services (api, scheduler, delivery-worker, …) — they MUST
#      talk to each other and to data infra via Kubernetes ClusterDNS.
#      No service ever uses localhost or any external endpoint.
#
# scripts/inject-secrets.sh strips every HOST_ key when populating the
# `hatch-secrets` k8s Secret, so pods cannot accidentally pick up the host
# variants.
#
# Copy this file to .env and replace placeholders before running `make up`.

# ─── HOST tools (port-forwarded) ──────────────────────────────────────────
HOST_DATABASE_URL=postgres://hatch:hatchpass@localhost:5432/hatch?sslmode=disable
HOST_REDIS_ADDR=localhost:6379
HOST_KAFKA_BROKERS=localhost:9092

# ─── In-cluster service config (ClusterDNS only) ──────────────────────────
POSTGRES_HOST=postgres.hatch.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=hatch
POSTGRES_USER=hatch
POSTGRES_PASSWORD=hatchpass
DATABASE_URL=postgres://hatch:hatchpass@postgres.hatch.svc.cluster.local:5432/hatch?sslmode=disable

REDIS_ADDR=redis.hatch.svc.cluster.local:6379

KAFKA_BROKERS=kafka.hatch.svc.cluster.local:9092

OTLP_ENDPOINT=observability-tempo.observability.svc.cluster.local:4317
LOKI_ENDPOINT=http://observability-loki-gateway.observability.svc.cluster.local

# ─── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ─── Alertmanager email receiver (placeholders) ───────────────────────────
ALERTMANAGER_SMTP_HOST=smtp.example.com:587
ALERTMANAGER_SMTP_FROM=alerts@example.com
ALERTMANAGER_SMTP_USER=
ALERTMANAGER_SMTP_PASSWORD=

# ─── Hatch API service (Phase 1) ──────────────────────────────────────────
# Service binds to 9021 in-cluster AND on the host port-forward (no remap).
API_PORT=9021
# Admin Bearer token. Used by /admin/* endpoints.
ADMIN_API_KEY=changeme-admin-key
# Tink AES256-GCM keyset (base64 JSON). Generate with `make gen-provider-key`.
PROVIDER_CRED_KEY=
BCRYPT_COST=12
API_MAX_BODY_BYTES=65536
# Toggle Swagger UI at /swagger/index.html. Default on for dev.
API_ENABLE_SWAGGER=true
# Minimum time between now and deliver_at. Default 1h (production). Set lower
# for local dev / verify runs so test schedules can fire quickly.
API_MIN_SCHEDULE_HORIZON=2m

# ─── Hatch scheduler service (Phase 2) ────────────────────────────────────
# Admin / observability HTTP port. Walks forward from the API's 9021.
SCHEDULER_ADMIN_PORT=9022
# bbolt file path inside the pod. Mounted from a per-pod PVC in helm.
SCHEDULER_WHEEL_DB_PATH=/var/lib/hatch/wheel.db
# Bounded channels between the 3 scheduler goroutines.
SCHEDULER_SCHEDULE_CHANNEL_BUFFER=100000
SCHEDULER_CLEAR_CHANNEL_BUFFER=64
# POD_INDEX / TOTAL_PODS are injected by the StatefulSet at runtime
# (POD_INDEX is derived from the pod ordinal). `make run-scheduler` falls
# back to defaults (0 / 1) so a single local process behaves as one shard.

# ─── Hatch delivery worker (Phase 3) ──────────────────────────────────────
# Admin / observability HTTP port. Walks forward from the scheduler's 9022.
DELIVERY_ADMIN_PORT=9023
# Kafka consumer group for emails.due and the per-batch fetch cap.
DELIVERY_CONSUMER_GROUP=delivery-workers
DELIVERY_BATCH_SIZE=1000

# ─── Mock provider tuning (vendor=mock; used by benchmarks + verify) ──────
MOCK_PROVIDER_LATENCY_MS=150
MOCK_PROVIDER_LATENCY_JITTER_MS=50
MOCK_PROVIDER_ERROR_RATE=0.001
MOCK_PROVIDER_RATE_LIMIT_RATE=0.0

# ─── Resend (real provider) verification ──────────────────────────────────
# `make verify` always exercises a real Resend send. Put your Resend API key
# here (never commit a real key) and verify the From domain in the Resend
# dashboard first. The default recipient is Resend's sandbox address, which is
# accepted without delivering to a real inbox.
VERIFY_RESEND_API_KEY=
VERIFY_RESEND_FROM=verify@nexia.hishaam.dev
VERIFY_RESEND_TO=delivered@resend.dev
